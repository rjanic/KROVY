<Window x:Class="AcKrovy.AutoCAD.UI.CustomElementDefinitionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:localization="clr-namespace:AcKrovy.AutoCAD.UI.Localization"
        Title="{localization:Loc CustomWindow_Title}"
        Width="500"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="155" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" FontSize="15" FontWeight="SemiBold"
                   Text="{localization:Loc CustomWindow_Heading}" />

        <RadioButton x:Name="UseExistingRadioButton" Grid.Row="2" Grid.ColumnSpan="2"
                     Margin="0,3" Checked="ModeChanged"
                     Content="{localization:Loc CustomWindow_UseExisting}" />
        <ComboBox x:Name="ExistingDefinitionComboBox" Grid.Row="3" Grid.ColumnSpan="2"
                  Margin="22,3,0,3" DisplayMemberPath="DisplayName" />

        <RadioButton x:Name="CreateNewRadioButton" Grid.Row="5" Grid.ColumnSpan="2"
                     Margin="0,3" Checked="ModeChanged"
                     Content="{localization:Loc CustomWindow_CreateNew}" />
        <Grid Grid.Row="6" Grid.ColumnSpan="2" Margin="22,3,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="133" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                       Text="{localization:Loc CustomWindow_Name}" />
            <TextBox x:Name="NameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,3" />
            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                       Text="{localization:Loc CustomWindow_Prefix}" />
            <TextBox x:Name="PrefixTextBox" Grid.Row="1" Grid.Column="1" Margin="0,3"
                     MaxLength="8" />
        </Grid>

        <StackPanel Grid.Row="8" Grid.ColumnSpan="2" HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="105" Margin="0,0,8,0" Padding="8,4"
                    Click="Cancel_Click" IsCancel="True"
                    Content="{localization:Loc EditWindow_Cancel}" />
            <Button Width="105" Padding="8,4" Click="Save_Click" IsDefault="True"
                    Content="{localization:Loc CustomWindow_Continue}" />
        </StackPanel>
    </Grid>
</Window>
