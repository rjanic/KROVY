<Window x:Class="AcKrovy.AutoCAD.UI.CustomElementDefinitionRenameWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:localization="clr-namespace:AcKrovy.AutoCAD.UI.Localization"
        Title="{localization:Loc CustomRenameWindow_Title}"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Text="{localization:Loc CustomRenameWindow_Heading}" />

        <TextBlock Grid.Row="2" Grid.Column="0"
                   VerticalAlignment="Center"
                   Text="{localization:Loc CustomWindow_Name}" />
        <TextBox x:Name="NameTextBox"
                 Grid.Row="2"
                 Grid.Column="1"
                 MaxLength="80"
                 Margin="0,3" />

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="105"
                    Margin="0,0,8,0"
                    Padding="8,4"
                    IsCancel="True"
                    Click="Cancel_Click"
                    Content="{localization:Loc EditWindow_Cancel}" />
            <Button Width="105"
                    Padding="8,4"
                    IsDefault="True"
                    Click="Save_Click"
                    Content="{localization:Loc SettingsWindow_Save}" />
        </StackPanel>
    </Grid>
</Window>
