<Window x:Class="AcKrovy.AutoCAD.UI.ElementEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ACAD KROVY – údaje prvkov"
        Width="580"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="165" />
            <ColumnDefinition Width="38" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" FontSize="15" FontWeight="SemiBold" Text="Údaje vybraných prvkov" />

        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Typ prvku" />
        <CheckBox x:Name="ChangeTypeCheckBox" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" ToolTip="Zmeniť" />
        <ComboBox x:Name="ElementTypeComboBox" Grid.Row="2" Grid.Column="2" MinWidth="210" />

        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Šírka [mm]" />
        <CheckBox x:Name="ChangeWidthCheckBox" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" ToolTip="Zmeniť" />
        <TextBox x:Name="WidthTextBox" Grid.Row="3" Grid.Column="2" Margin="0,4" />

        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Výška [mm]" />
        <CheckBox x:Name="ChangeHeightCheckBox" Grid.Row="4" Grid.Column="1" VerticalAlignment="Center" ToolTip="Zmeniť" />
        <TextBox x:Name="HeightTextBox" Grid.Row="4" Grid.Column="2" Margin="0,4" />

        <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Sklon [°]" />
        <CheckBox x:Name="ChangeSlopeCheckBox" Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" ToolTip="Zmeniť" />
        <TextBox x:Name="SlopeTextBox" Grid.Row="5" Grid.Column="2" Margin="0,4" />

        <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="Strešná rovina" />
        <CheckBox x:Name="ChangeRoofPlaneCheckBox" Grid.Row="6" Grid.Column="1" VerticalAlignment="Center" ToolTip="Zmeniť" />
        <TextBox x:Name="RoofPlaneTextBox" Grid.Row="6" Grid.Column="2" Margin="0,4" />

        <TextBlock Grid.Row="7" Grid.Column="0" VerticalAlignment="Center" Text="Výrobný prídavok [mm]" />
        <CheckBox x:Name="ChangeAllowanceCheckBox" Grid.Row="7" Grid.Column="1" VerticalAlignment="Center" ToolTip="Zmeniť" />
        <StackPanel Grid.Row="7" Grid.Column="2" Orientation="Horizontal" Margin="0,4">
            <TextBox x:Name="AllowanceTextBox" Width="105" />
            <Button Width="215" Margin="8,0,0,0" Padding="8,3" Click="UseDefaultAllowance_Click">Použiť predvolený podľa typu</Button>
        </StackPanel>

        <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Text="Režim dĺžky" />
        <CheckBox x:Name="ChangeLengthModeCheckBox" Grid.Row="8" Grid.Column="1" VerticalAlignment="Center" ToolTip="Zmeniť" />
        <ComboBox x:Name="LengthModeComboBox" Grid.Row="8" Grid.Column="2" />

        <TextBlock Grid.Row="9" Grid.Column="0" VerticalAlignment="Center" Text="Ručná dĺžka [mm]" />
        <CheckBox x:Name="ChangeManualLengthCheckBox" Grid.Row="9" Grid.Column="1" VerticalAlignment="Center" ToolTip="Zmeniť" />
        <TextBox x:Name="ManualLengthTextBox" Grid.Row="9" Grid.Column="2" Margin="0,4" />

        <TextBlock Grid.Row="10" Grid.Column="0" VerticalAlignment="Center" Text="Materiál" />
        <CheckBox x:Name="ChangeMaterialCheckBox" Grid.Row="10" Grid.Column="1" VerticalAlignment="Center" ToolTip="Zmeniť" />
        <TextBox x:Name="MaterialTextBox" Grid.Row="10" Grid.Column="2" Margin="0,4" />

        <StackPanel Grid.Row="12" Grid.ColumnSpan="3" HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Width="105" Margin="0,0,8,0" Padding="8,4" Click="Cancel_Click" IsCancel="True">Zrušiť</Button>
            <Button Width="105" Padding="8,4" Click="Save_Click" IsDefault="True">Použiť</Button>
        </StackPanel>
    </Grid>
</Window>
