<Window x:Class="AcKrovy.AutoCAD.UI.LayerSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ACAD KROVY – nastavenia prvkov a hladín"
        Width="900"
        Height="485"
        MinWidth="860"
        MinHeight="430"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="16" FontWeight="SemiBold" Text="Nastavenia prvkov a hladín" />
        <TextBlock Grid.Row="2" TextWrapping="Wrap" Foreground="#555555">
            Nastavenia sa ukladajú pre aktuálny účet Windows. Hladiny určujú zaradenie prvkov vo výkrese.
            Predvolené prídavky možno uložiť iba pre nové prvky alebo ich aplikovať aj na existujúce prvky vo výkrese.
        </TextBlock>

        <TabControl Grid.Row="4">
            <TabItem Header="Hladiny">
                <DataGrid x:Name="StylesDataGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserSortColumns="False"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Typ prvku" Binding="{Binding ElementLabel}" IsReadOnly="True" Width="170" />
                        <DataGridTextColumn Header="Názov hladiny" Binding="{Binding LayerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                        <DataGridTemplateColumn Header="Farba hladiny" Width="200">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="18" Height="18" Margin="0,0,8,0" BorderBrush="#555555" BorderThickness="1" Background="{Binding SelectedColor.Brush}" />
                                        <TextBlock VerticalAlignment="Center" Text="{Binding SelectedColor.Label}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox ItemsSource="{Binding DataContext.ColorOptions, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                              SelectedItem="{Binding SelectedColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="18" Height="18" Margin="0,0,8,0" BorderBrush="#555555" BorderThickness="1" Background="{Binding Brush}" />
                                                    <TextBlock VerticalAlignment="Center" Text="{Binding Label}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Výrobné prídavky">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" TextWrapping="Wrap" Foreground="#555555">
                        Predvolený prídavok na rez sa použije pri novom priradení prvku. Pri uložení si môžeš vybrať, či sa má premietnuť aj do existujúcich prvkov.
                    </TextBlock>
                    <DataGrid x:Name="DefaultsDataGrid"
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserSortColumns="False"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Typ prvku" Binding="{Binding ElementLabel}" IsReadOnly="True" Width="220" />
                            <DataGridTextColumn Header="Predvolený prídavok na rez [mm]" Binding="{Binding CuttingAllowanceMmText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Width="165" HorizontalAlignment="Left" Padding="8,4" Click="RestoreDefaults_Click">Obnoviť predvolené</Button>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Width="90" Margin="0,0,8,0" Padding="8,4" Click="Cancel_Click" IsCancel="True">Zrušiť</Button>
                <Button Width="185" Margin="0,0,8,0" Padding="8,4" Click="SaveNewElementsOnly_Click">Uložiť iba pre nové prvky</Button>
                <Button Width="175" Margin="0,0,8,0" Padding="8,4" Click="SaveAndApplySelected_Click">Uložiť a aplikovať na výber</Button>
                <Button Width="175" Padding="8,4" Click="SaveAndApply_Click" IsDefault="True">Uložiť a aplikovať na všetky</Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
